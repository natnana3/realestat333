// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ListingStatus {
  ACTIVE
  PENDING
  SOLD
  WITHDRAWN
  EXPIRED
  COMING_SOON
  TEMP_OFF_MARKET
}

enum ListingTransactionType {
  FOR_SALE
  FOR_RENT
}

model County {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(96)
  slug      String   @unique @db.VarChar(96)
  stateCode String   @default("MD") @db.Char(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]

  @@index([stateCode, slug])
}

model Listing {
  id String @id @default(cuid())

  // IDX/RESO identifiers
  sourceSystem String  @db.VarChar(64) // e.g. BrightMLS / RESO provider name
  sourceKey    String  @db.VarChar(128) // e.g. ListingKey / UUID from feed
  mlsNumber    String? @db.VarChar(64)

  transactionType ListingTransactionType
  status          ListingStatus

  // Canonical SEO routing
  slug      String  @unique @db.VarChar(160)
  urlPath   String  @unique @db.VarChar(220) // e.g. /listings/anne-arundel-county/123-main-st-annapolis-md-21401/abc123

  // Address + geo
  street1      String?  @db.VarChar(128)
  street2      String?  @db.VarChar(128)
  city         String?  @db.VarChar(96)
  stateCode    String   @default("MD") @db.Char(2)
  postalCode   String?  @db.VarChar(16)
  countyName   String?  @db.VarChar(96) // raw from feed
  latitude     Decimal? @db.Decimal(9, 6)
  longitude    Decimal? @db.Decimal(9, 6)

  // Basics
  propertyType String?   @db.VarChar(64) // SingleFamilyResidence, Condo, Townhouse, etc.
  beds         Int?
  bathsFull    Int?
  bathsHalf    Int?
  livingAreaSqft Int?
  lotSizeSqft    Int?
  yearBuilt      Int?

  // Pricing
  listPrice   Int?
  rentPrice   Int?
  currency    String @default("USD") @db.Char(3)

  // Content
  headline    String? @db.VarChar(140)
  publicRemarks String?

  // Timing
  listDate     DateTime?
  closeDate    DateTime?
  statusChange DateTime?

  // Compliance + legal (placeholder for vendor-specific constraints)
  displayAllowed Boolean @default(true)

  // Raw RESO/IDX payload for forward compatibility (exact fields vary by MLS)
  raw Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  photos ListingPhoto[]

  countyId String?
  county   County? @relation(fields: [countyId], references: [id], onDelete: SetNull)

  @@unique([sourceSystem, sourceKey])
  @@index([status, transactionType])
  @@index([stateCode, city])
  @@index([countyId])
  @@index([listPrice])
}

model ListingPhoto {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  url       String  @db.VarChar(600)
  alt       String? @db.VarChar(180)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@index([listingId, sortOrder])
}
